        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"openai/gpt-4o-mini\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Kamu adalah HR Helpdesk Assistant. Tugasmu mengklasifikasikan keluhan karyawan ke dalam kategori Payroll, Benefit, atau Konflik serta menentukan prioritas High, Medium, atau Low. Balas hanya dengan JSON valid tanpa penjelasan tambahan.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Keluhan karyawan: {{$json.message.text}}. Format jawaban wajib: {\\\"category\\\":\\\"Payroll|Benefit|Konflik\\\",\\\"priority\\\":\\\"High|Medium|Low\\\"}\"\n    }\n  ],\n  \"temperature\": 0.1\n}",
