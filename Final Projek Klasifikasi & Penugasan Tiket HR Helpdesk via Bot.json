      "name": "AI Classification"
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $json.choices[0].message.content;\n\n// Mengubah hasil JSON dari AI menjadi object JavaScript\nconst classificationResult = JSON.parse(aiResponse);\n\n// Mengambil pesan asli dari Telegram\nconst originalMessage = $('Telegram Trigger').first().json.message.text;\n\n// Mengirim data yang akan digunakan pada node berikutnya\nreturn [\n  {\n    json: {\n      category: classificationResult.category,\n      priority: classificationResult.priority,\n      user_message: originalMessage\n    }\n  }\n];"
      },
